# =============================================================================
# Xplora — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: Variables left blank (=) will use sensible defaults hardcoded in the
# backend code. Only fill in what you need to change.
#
# DATABASE
# -----------------------------------------------------------------------------
# Required. PostgreSQL connection string (SQLite is no longer supported).
#
# Examples:
# =============================================================================

DATABASE_URL=

# -----------------------------------------------------------------------------
# PostgreSQL Connection Pool
# -----------------------------------------------------------------------------
# DB_POOL_SIZE       — Base number of connections kept in the pool (default: 10)
# DB_MAX_OVERFLOW    — Additional connections allowed beyond pool_size (default: 20)
# DB_POOL_TIMEOUT    — Seconds to wait for a connection from the pool (default: 30)
# DB_POOL_RECYCLE    — Seconds after which idle connections are recycled (default: 1800)
#                      Set lower than your PostgreSQL idle_timeout to avoid stale connections.
# DB_POOL_PRE_PING   — Verify connection is alive before handing it out (default: true)
#                      Recommended "true" for production.
DB_POOL_SIZE=
DB_MAX_OVERFLOW=
DB_POOL_TIMEOUT=
DB_POOL_RECYCLE=
DB_POOL_PRE_PING=


# =============================================================================
# AI / LLM API KEYS
# -----------------------------------------------------------------------------
# At least one of DEEPSEEK_API_KEY or OPENAI_API_KEY must be configured for AI
# recommendations to work.
#
# Get your keys here:
#   DeepSeek: https://platform.deepseek.com/
#   OpenAI:   https://platform.openai.com/
# =============================================================================
DEEPSEEK_API_KEY=
OPENAI_API_KEY=


# =============================================================================
# MOVIE DATABASE API KEYS
# -----------------------------------------------------------------------------
# Required for TMDB/OMDb movie search & metadata scraping.
# Configured either here or via the Admin UI → Settings page.
#
# Get your keys here:
#   TMDB: https://www.themoviedb.org/settings/api
#   OMDb: https://www.omdbapi.com/apikey.aspx
# =============================================================================
TMDB_API_KEY=
OMDB_API_KEY=


# =============================================================================
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Used to sign and verify user session tokens.
# CHANGE THIS in production — use a long, random value (e.g. openssl rand -hex 32)
# =============================================================================
JWT_SECRET=xplora-dev-secret-change-in-production
